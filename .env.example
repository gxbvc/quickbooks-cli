# Intuit developer app credentials (developer.intuit.com -> your app -> Keys & credentials)
QB_CLIENT_ID=
QB_CLIENT_SECRET=

# sandbox | production (base URL + which app keys the tokens belong to)
QB_ENVIRONMENT=sandbox

# Company (realm) ID to query. Sandbox realm initially; `quickbooks-cli auth`
# captures it from the OAuth callback and offers to write it here.
QB_REALM_ID=

# Optional: override the OAuth redirect URI. Must exactly match a redirect URI
# registered on the Intuit app. Default: http://localhost:3456/callback
# (localhost is sandbox-only; production needs a public HTTPS callback page —
# see README "Production keys").
# QB_REDIRECT_URI=
